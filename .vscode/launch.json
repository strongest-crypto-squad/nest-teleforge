{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Start NestJS (debug)",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": ["exec", "nest", "start", "playground", "--debug"],
      "console": "integratedTerminal",
      "sourceMaps": true,
      "skipFiles": ["<node_internals>/**"]
    }
  ]
}
