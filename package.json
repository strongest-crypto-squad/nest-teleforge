{
  "name": "nest-teleforge",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "dev": "nest start playground --debug --watch",
    "lib:build": "pnpm --dir libs/my-lib run build",
    "lib:pack": "mkdir -p artifacts/npm && pnpm --dir libs/my-lib pack --pack-destination ../../artifacts/npm",
    "lib:publish": "pnpm --dir libs/my-lib publish",
    "test": "jest",
    "test:file": "node scripts/run-jest.cjs file",
    "test:case": "node scripts/run-jest.cjs case",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:live": "jest -c jest.live.config.cjs",
    "test:live:file": "node scripts/run-jest.cjs live-file",
    "test:live:case": "node scripts/run-jest.cjs live-case",
    "tg:send-help": "node scripts/send-help.cjs",
    "tg:gen-session": "node scripts/gen-user-session.cjs"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.12.4",
  "devDependencies": {
    "@nestjs/cli": "11.0.16",
    "@nestjs/common": "11.1.12",
    "@nestjs/config": "4.0.2",
    "@nestjs/core": "11.1.12",
    "@nestjs/platform-express": "11.1.12",
    "@types/jest": "30.0.0",
    "class-validator": "0.14.3",
    "jest": "30.2.0",
    "qrcode-terminal": "0.12.0",
    "reflect-metadata": "0.2.2",
    "telegraf": "4.16.3",
    "telegram": "2.26.22",
    "ts-jest": "29.4.6",
    "ts-loader": "9.5.4",
    "typescript": "5.9.3",
    "webpack": "5.104.1",
    "webpack-cli": "6.0.1"
  }
}
