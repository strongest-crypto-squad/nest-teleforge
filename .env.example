# Telegram bot token for application runtime
TELEGRAM_KEY=

# Live test chat id (group/channel/user id)
TG_TEST_CHAT_ID=

# Telegram user MTProto credentials for live tests
TG_USER_API_ID=
TG_USER_API_HASH=
TG_USER_SESSION=

# Optional: form timeout in milliseconds for e2e flows
TG_FORM_TIMEOUT_MS=10000

# Optional: debug incoming Telegram updates
TG_DEBUG_UPDATES=0
TG_DEBUG_UPDATES_FILE=0
TG_DEBUG_UPDATES_LOG_PATH=logs/telegram-updates.log

# Optional: menu callback HMAC secret
MENU_HMAC_SECRET=
